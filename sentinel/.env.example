# ── AI Engine ───────────────────────────────────────────
# Required for all AI features. Get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Threat Intelligence Feeds (all free) ────────────────
# AbuseIPDB — 1000 checks/day free: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# VirusTotal — 500 queries/day free: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# AlienVault OTX — free: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_key_here

# IPinfo — 50k/month free: https://ipinfo.io/account/token
IPINFO_API_KEY=your_ipinfo_key_here

# Shodan — optional, basic IP info on free tier: https://account.shodan.io
SHODAN_API_KEY=your_shodan_key_here

# ── Email Notifications ──────────────────────────────────
ALERT_EMAIL=alerts@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
# For Gmail: use App Password from https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_app_password_here

# ── Organization ─────────────────────────────────────────
ORG_NAME=My Business Name
ORG_TYPE=SME

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./sentinel.db
